#!/usr/bin/env bash
#
# netprobe - Continuous network monitor to prove router vs ISP issues
# Usage:
#   netprobe              - Run interactive dashboard (default 5min)
#   netprobe --duration 30 - Run for 30 minutes
#   netprobe --mtr        - Run mtr report (requires sudo)
#   netprobe --report     - Generate summary from latest log
#   netprobe --daemon     - Run in background, logging continuously
#   netprobe --stop       - Stop background daemon

set -euo pipefail

LOGDIR="$HOME/network-monitor/logs"
PIDFILE="$LOGDIR/.netprobe.pid"
GATEWAY="$(route -n get default 2>/dev/null | awk '/gateway:/{print $2}')"
TARGETS=("$GATEWAY" "1.1.1.1" "8.8.8.8")
TARGET_NAMES=("Router/Gateway" "Cloudflare DNS" "Google DNS")
INTERVAL=1  # seconds between pings
DURATION=5  # minutes

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

mkdir -p "$LOGDIR"

usage() {
    echo "NotMyRouter - Network monitor to prove router vs ISP issues"
    echo ""
    echo "Usage:"
    echo "  netprobe                    Interactive dashboard (5 min)"
    echo "  netprobe --duration <min>   Set duration in minutes"
    echo "  netprobe --mtr              Run mtr trace (needs sudo)"
    echo "  netprobe --report           Show summary of latest log"
    echo "  netprobe --daemon           Run in background, log continuously"
    echo "  netprobe --web              Launch web dashboard in browser"
    echo "  netprobe --stop             Stop daemon + web dashboard"
    echo "  netprobe --stop-web         Stop only the web dashboard"
    echo "  netprobe --help             Show this help"
    echo ""
    echo "Gateway detected: $GATEWAY"
}

# Ping a target, return "latency loss" (loss = 0 or 100)
do_ping() {
    local target="$1"
    local result
    result=$(ping -c 1 -W 2 "$target" 2>/dev/null)
    if [ $? -eq 0 ]; then
        local ms
        # macOS ping: round-trip min/avg/max/stddev = 4.741/4.741/4.741/0.000 ms
        ms=$(echo "$result" | awk -F'/' '/round-trip/{print $5}')
        # Fallback: try Linux-style time=X.X ms
        if [ -z "$ms" ]; then
            ms=$(echo "$result" | awk -F'[= ]' '/time=/{for(i=1;i<=NF;i++) if($i=="time") print $(i+1)}')
        fi
        echo "${ms:-0} 0"
    else
        echo "0 100"
    fi
}

# Run the interactive dashboard
run_dashboard() {
    local duration_secs=$((DURATION * 60))
    local logfile="$LOGDIR/probe_$(date +%Y%m%d_%H%M%S).csv"
    local start_time=$SECONDS

    # CSV header
    echo "timestamp,target,target_name,latency_ms,packet_loss" > "$logfile"

    # Stats arrays
    declare -A total_pings loss_count latency_sum latency_max latency_min
    declare -A recent_history  # last 60 results for sparkline
    for i in "${!TARGETS[@]}"; do
        local t="${TARGETS[$i]}"
        total_pings[$t]=0
        loss_count[$t]=0
        latency_sum[$t]=0
        latency_max[$t]=0
        latency_min[$t]=99999
        recent_history[$t]=""
    done

    echo -e "${BOLD}NotMyRouter${NC} - monitoring for ${DURATION} min | logging to ${DIM}${logfile}${NC}"
    echo -e "Gateway: ${CYAN}${GATEWAY}${NC} | Targets: ${TARGETS[*]}"
    echo -e "Press Ctrl+C to stop early\n"

    trap 'echo -e "\n\n${BOLD}Stopped.${NC} Log: $logfile"; generate_report "$logfile"; exit 0' INT

    while [ $((SECONDS - start_time)) -lt $duration_secs ]; do
        local elapsed=$((SECONDS - start_time))
        local remaining=$(( (duration_secs - elapsed) / 60 ))
        local remaining_sec=$(( (duration_secs - elapsed) % 60 ))
        local ts
        ts=$(date '+%Y-%m-%d %H:%M:%S')

        # Clear and redraw
        printf "\033[2K\r"
        echo -e "${DIM}[$ts] ${remaining}m${remaining_sec}s remaining${NC}"
        echo ""

        for i in "${!TARGETS[@]}"; do
            local t="${TARGETS[$i]}"
            local name="${TARGET_NAMES[$i]}"
            local result
            result=$(do_ping "$t")
            local lat=$(echo "$result" | awk '{print $1}')
            local loss=$(echo "$result" | awk '{print $2}')

            # Log to CSV
            echo "$ts,$t,$name,$lat,$loss" >> "$logfile"

            # Update stats
            total_pings[$t]=$(( ${total_pings[$t]} + 1 ))
            if [ "$loss" -eq 100 ]; then
                loss_count[$t]=$(( ${loss_count[$t]} + 1 ))
            else
                local lat_int=${lat%.*}
                lat_int=${lat_int:-0}
                latency_sum[$t]=$(( ${latency_sum[$t]} + lat_int ))
                if [ "$lat_int" -gt "${latency_max[$t]}" ]; then
                    latency_max[$t]=$lat_int
                fi
                if [ "$lat_int" -lt "${latency_min[$t]}" ]; then
                    latency_min[$t]=$lat_int
                fi
            fi

            # Build sparkline (last 30 results)
            local spark_char
            if [ "$loss" -eq 100 ]; then
                spark_char="X"
            else
                local lat_int=${lat%.*}
                lat_int=${lat_int:-0}
                if [ "$lat_int" -lt 10 ]; then spark_char="▁"
                elif [ "$lat_int" -lt 25 ]; then spark_char="▂"
                elif [ "$lat_int" -lt 50 ]; then spark_char="▃"
                elif [ "$lat_int" -lt 75 ]; then spark_char="▅"
                elif [ "$lat_int" -lt 100 ]; then spark_char="▆"
                elif [ "$lat_int" -lt 200 ]; then spark_char="▇"
                else spark_char="█"
                fi
            fi
            recent_history[$t]="${recent_history[$t]}${spark_char}"
            # Keep last 40 chars
            if [ ${#recent_history[$t]} -gt 40 ]; then
                recent_history[$t]="${recent_history[$t]: -40}"
            fi

            # Calculate running loss %
            local loss_pct=0
            if [ "${total_pings[$t]}" -gt 0 ]; then
                loss_pct=$(( (${loss_count[$t]} * 100) / ${total_pings[$t]} ))
            fi

            # Calculate avg latency
            local successful=$(( ${total_pings[$t]} - ${loss_count[$t]} ))
            local avg_lat=0
            if [ "$successful" -gt 0 ]; then
                avg_lat=$(( ${latency_sum[$t]} / successful ))
            fi

            # Color-code the status
            local status_color="$GREEN"
            local status_icon="OK"
            if [ "$loss" -eq 100 ]; then
                status_color="$RED"
                status_icon="LOST"
            elif [ "${lat%.*}" -gt 100 ] 2>/dev/null; then
                status_color="$YELLOW"
                status_icon="SLOW"
            fi

            # Loss % color
            local loss_color="$GREEN"
            if [ "$loss_pct" -gt 0 ] && [ "$loss_pct" -lt 5 ]; then
                loss_color="$YELLOW"
            elif [ "$loss_pct" -ge 5 ]; then
                loss_color="$RED"
            fi

            printf "  %-18s %-16s ${status_color}%-6s${NC} %6s ms  avg:%3d ms  max:%3d ms  ${loss_color}loss:%2d%%${NC}\n" \
                "$name" "$t" "$status_icon" "$lat" "$avg_lat" "${latency_max[$t]}" "$loss_pct"
            printf "  ${DIM}%s${NC}\n" "${recent_history[$t]}"
        done

        # Quick verdict
        echo ""
        local router_loss_pct=0
        local router_total=${total_pings[$GATEWAY]}
        if [ "$router_total" -gt 0 ]; then
            router_loss_pct=$(( (${loss_count[$GATEWAY]} * 100) / $router_total ))
        fi

        local inet_loss_pct=0
        local inet_total=${total_pings[1.1.1.1]}
        if [ "$inet_total" -gt 0 ]; then
            inet_loss_pct=$(( (${loss_count[1.1.1.1]} * 100) / $inet_total ))
        fi

        if [ "$router_loss_pct" -ge 5 ]; then
            echo -e "  ${RED}${BOLD}VERDICT: Router/Wi-Fi problem detected${NC} - loss starts at your gateway"
        elif [ "$inet_loss_pct" -ge 5 ] && [ "$router_loss_pct" -lt 2 ]; then
            echo -e "  ${RED}${BOLD}VERDICT: ISP (Cox) problem detected${NC} - router fine, loss starts upstream"
        elif [ "$inet_loss_pct" -ge 2 ]; then
            echo -e "  ${YELLOW}${BOLD}VERDICT: Possible ISP issue${NC} - some upstream loss detected"
        else
            echo -e "  ${GREEN}${BOLD}VERDICT: Network looks healthy${NC}"
        fi

        # Move cursor up to overwrite on next iteration
        # header area = 3 lines per target (stat + sparkline) + verdict + spacer
        local lines_to_move=$(( (${#TARGETS[@]} * 2) + 3 ))
        printf "\033[%dA" "$lines_to_move"

        sleep "$INTERVAL"
    done

    # Final output
    printf "\033[%dB" "$(( (${#TARGETS[@]} * 2) + 3 ))"
    echo -e "\n${BOLD}Monitoring complete.${NC} Log saved to: $logfile"
    generate_report "$logfile"
}

# Generate a human-readable report from a CSV log
generate_report() {
    local logfile="${1:-$(ls -t "$LOGDIR"/probe_*.csv 2>/dev/null | head -1)}"
    if [ -z "$logfile" ] || [ ! -f "$logfile" ]; then
        echo "No log file found."
        return 1
    fi

    local report_file="${logfile%.csv}_REPORT.txt"
    local total_lines=$(( $(wc -l < "$logfile") - 1 ))
    local first_ts=$(awk -F, 'NR==2{print $1}' "$logfile")
    local last_ts=$(awk -F, 'END{print $1}' "$logfile")

    {
        echo "=============================================="
        echo "  NETWORK MONITORING REPORT"
        echo "=============================================="
        echo "Period: $first_ts  ->  $last_ts"
        echo "Total probes: $total_lines"
        echo ""

        # Per-target stats
        for i in "${!TARGETS[@]}"; do
            local t="${TARGETS[$i]}"
            local name="${TARGET_NAMES[$i]}"
            local target_lines=$(awk -F, -v tgt="$t" '$2==tgt' "$logfile" | wc -l | tr -d ' ')
            local lost=$(awk -F, -v tgt="$t" '$2==tgt && $5==100' "$logfile" | wc -l | tr -d ' ')
            local loss_pct=0
            if [ "$target_lines" -gt 0 ]; then
                loss_pct=$(( (lost * 100) / target_lines ))
            fi
            local avg_lat=$(awk -F, -v tgt="$t" '$2==tgt && $5!=100 && $4+0>0 {sum+=$4; n++} END{if(n>0) printf "%.1f", sum/n; else print "N/A"}' "$logfile")
            local max_lat=$(awk -F, -v tgt="$t" '$2==tgt && $5!=100 {if($4+0>max) max=$4+0} END{printf "%.1f", max}' "$logfile")
            local jitter=$(awk -F, -v tgt="$t" 'BEGIN{prev=-1} $2==tgt && $5!=100 && $4+0>0 {if(prev>=0){d=$4-prev; if(d<0)d=-d; sum+=d; n++} prev=$4} END{if(n>0) printf "%.1f", sum/n; else print "N/A"}' "$logfile")

            echo "--- $name ($t) ---"
            echo "  Probes:       $target_lines"
            echo "  Packet Loss:  ${loss_pct}% ($lost lost)"
            echo "  Avg Latency:  ${avg_lat} ms"
            echo "  Max Latency:  ${max_lat} ms"
            echo "  Avg Jitter:   ${jitter} ms"
            echo ""
        done

        # Automated verdict
        echo "=============================================="
        echo "  DIAGNOSIS"
        echo "=============================================="
        local router_loss=$(awk -F, -v tgt="$GATEWAY" '$2==tgt && $5==100' "$logfile" | wc -l | tr -d ' ')
        local router_total=$(awk -F, -v tgt="$GATEWAY" '$2==tgt' "$logfile" | wc -l | tr -d ' ')
        local inet_loss=$(awk -F, '$2=="1.1.1.1" && $5==100' "$logfile" | wc -l | tr -d ' ')
        local inet_total=$(awk -F, '$2=="1.1.1.1"' "$logfile" | wc -l | tr -d ' ')

        local router_loss_pct=0
        local inet_loss_pct=0
        [ "$router_total" -gt 0 ] && router_loss_pct=$(( (router_loss * 100) / router_total ))
        [ "$inet_total" -gt 0 ] && inet_loss_pct=$(( (inet_loss * 100) / inet_total ))

        if [ "$router_loss_pct" -ge 5 ]; then
            echo ""
            echo "  >> YOUR ROUTER/WI-FI IS THE PROBLEM <<"
            echo ""
            echo "  Packet loss to your own gateway: ${router_loss_pct}%"
            echo "  This means packets are dying between your device"
            echo "  and your router. Cox is not at fault here."
            echo ""
            echo "  Possible causes:"
            echo "    - Wi-Fi interference or weak signal"
            echo "    - Router overloaded or needs reboot/replacement"
            echo "    - Too many devices on the network"
            echo "    - Bad ethernet cable (if wired)"
        elif [ "$inet_loss_pct" -ge 5 ] && [ "$router_loss_pct" -lt 2 ]; then
            echo ""
            echo "  >> COX (ISP) IS THE PROBLEM <<"
            echo ""
            echo "  Router packet loss: ${router_loss_pct}% (healthy)"
            echo "  Internet packet loss: ${inet_loss_pct}% (bad)"
            echo ""
            echo "  Your local network is fine. Packets are being"
            echo "  lost AFTER leaving your router, on Cox's network."
            echo ""
            echo "  Use this report when calling Cox support."
            echo "  Key evidence: clean gateway, loss to public DNS."
        elif [ "$inet_loss_pct" -ge 2 ]; then
            echo ""
            echo "  >> LIKELY COX ISSUE (borderline) <<"
            echo ""
            echo "  Router loss: ${router_loss_pct}%"
            echo "  Internet loss: ${inet_loss_pct}%"
            echo ""
            echo "  Some upstream packet loss detected."
            echo "  Run a longer test (--duration 30) for stronger evidence."
        else
            echo ""
            echo "  >> NETWORK LOOKS HEALTHY <<"
            echo ""
            echo "  No significant packet loss detected during this"
            echo "  monitoring window. Try running during an incident."
        fi

        echo ""
        echo "=============================================="
        echo "  Log file: $logfile"
        echo "  Generated: $(date)"
        echo "=============================================="
    } | tee "$report_file"

    echo ""
    echo -e "${BOLD}Report saved to:${NC} $report_file"
}

# Run mtr trace
run_mtr() {
    echo -e "${BOLD}Running mtr trace to 1.1.1.1 (60 cycles)...${NC}"
    echo "This requires sudo and takes about 60 seconds."
    echo ""

    local mtr_log="$LOGDIR/mtr_$(date +%Y%m%d_%H%M%S).txt"

    sudo /opt/homebrew/sbin/mtr --report --report-cycles 60 1.1.1.1 | tee "$mtr_log"

    echo ""
    echo -e "${BOLD}MTR report saved to:${NC} $mtr_log"
    echo ""
    echo "How to read this:"
    echo "  - Hop 1 is your router ($GATEWAY)"
    echo "  - Look at Loss% column"
    echo "  - If loss starts at hop 1: router/Wi-Fi problem"
    echo "  - If hop 1 is clean but loss appears at hop 2+: Cox problem"
    echo "  - Loss at ONE hop but not later hops = that hop rate-limits ICMP (ignore it)"
}

# Daemon mode
run_daemon() {
    if [ -f "$PIDFILE" ]; then
        local old_pid
        old_pid=$(cat "$PIDFILE")
        if kill -0 "$old_pid" 2>/dev/null; then
            echo "Daemon already running (PID $old_pid). Use --stop first."
            exit 1
        fi
    fi

    local logfile="$LOGDIR/daemon_$(date +%Y%m%d_%H%M%S).csv"
    echo "timestamp,target,target_name,latency_ms,packet_loss" > "$logfile"

    echo "Starting background monitor..."
    echo "Log: $logfile"
    echo "Use 'netprobe --stop' to stop, 'netprobe --report' for summary."

    (
        while true; do
            local ts
            ts=$(date '+%Y-%m-%d %H:%M:%S')
            for i in "${!TARGETS[@]}"; do
                local t="${TARGETS[$i]}"
                local name="${TARGET_NAMES[$i]}"
                local result
                result=$(do_ping "$t")
                local lat=$(echo "$result" | awk '{print $1}')
                local loss=$(echo "$result" | awk '{print $2}')
                echo "$ts,$t,$name,$lat,$loss" >> "$logfile"
            done
            sleep 5
        done
    ) &

    echo $! > "$PIDFILE"
    echo "Daemon started (PID $(cat "$PIDFILE"))"
}

stop_daemon() {
    if [ -f "$PIDFILE" ]; then
        local pid
        pid=$(cat "$PIDFILE")
        if kill -0 "$pid" 2>/dev/null; then
            kill "$pid"
            rm -f "$PIDFILE"
            echo "Daemon stopped (PID $pid)."
            echo "Run 'netprobe --report' to see results."
        else
            rm -f "$PIDFILE"
            echo "Daemon was not running (stale PID file removed)."
        fi
    else
        echo "No daemon running."
    fi
}

# Web dashboard
run_web() {
    local web_pid_file="$LOGDIR/.webdashboard.pid"
    # Check if already running
    if [ -f "$web_pid_file" ]; then
        local old_pid
        old_pid=$(cat "$web_pid_file")
        if kill -0 "$old_pid" 2>/dev/null; then
            echo "Dashboard already running (PID $old_pid)"
            echo "Opening http://localhost:8457"
            open "http://localhost:8457"
            return
        fi
    fi
    # Start daemon if not running
    if [ ! -f "$PIDFILE" ] || ! kill -0 "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null; then
        echo "Starting probe daemon first..."
        run_daemon
    fi
    echo "Starting NotMyRouter dashboard on http://localhost:8457 ..."
    python3 "$HOME/network-monitor/server.py" &
    local web_pid=$!
    echo "$web_pid" > "$web_pid_file"
    sleep 1
    if kill -0 "$web_pid" 2>/dev/null; then
        echo "Dashboard running (PID $web_pid)"
        open "http://localhost:8457"
    else
        echo "Failed to start dashboard."
        rm -f "$web_pid_file"
    fi
}

stop_web() {
    local web_pid_file="$LOGDIR/.webdashboard.pid"
    if [ -f "$web_pid_file" ]; then
        local pid
        pid=$(cat "$web_pid_file")
        if kill -0 "$pid" 2>/dev/null; then
            kill "$pid"
            echo "Dashboard stopped (PID $pid)."
        fi
        rm -f "$web_pid_file"
    else
        echo "Dashboard not running."
    fi
}

# Parse args
case "${1:-}" in
    --help|-h)
        usage
        ;;
    --mtr)
        run_mtr
        ;;
    --report)
        generate_report "${2:-}"
        ;;
    --daemon)
        run_daemon
        ;;
    --stop)
        stop_daemon
        stop_web
        ;;
    --web)
        run_web
        ;;
    --stop-web)
        stop_web
        ;;
    --duration)
        DURATION="${2:-5}"
        run_dashboard
        ;;
    *)
        run_dashboard
        ;;
esac
